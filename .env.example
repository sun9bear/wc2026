# 复制为 .env.local 并填入真实值（.env.local 已被 .gitignore 忽略）

# Supabase（在 https://supabase.com 新建项目后，在 Project Settings → API 获取）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# football-data.org API token（拉赛程/比分，自动结算用）
FOOTBALL_API_KEY=

# DeepSeek LLM API key（生成赛事前瞻/小结）
DEEPSEEK_API_KEY=
