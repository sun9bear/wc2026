# 复制为 .env.local 并填入真实值（.env.local 已被 .gitignore 忽略）

# Supabase（在 https://supabase.com 新建项目后，在 Project Settings → API 获取）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 服务端密钥：代码读取的是 SUPABASE_SECRET_KEY（即 service_role 密钥）。
# 名字必须叫这个——结算 / 历史快照写入 / 内容生成全靠它，填错会静默不工作。
SUPABASE_SECRET_KEY=

# football-data.org API token（拉赛程/比分，自动结算用）
FOOTBALL_API_KEY=
# football-data.org 实时比分（FREE_PLUS_LIVESCORES 档）权益到期日，仅作直播 fallback 门控用。
# 到期后实时端点退回免费档（延迟比分），fallback 自动停用以免把延迟比分当实时显示。
# 不填则默认停用 football-data 实时 fallback（直播仍走 APISPORTS_KEY）。
FD_LIVESCORES_UNTIL=2026-07-14

# API-Football / api-sports.io（v3.football.api-sports.io）：实时进行中比分主源。
APISPORTS_KEY=

# The Odds API（多机构赔率共识，仅取胜平负概率，不展示任何盘口/赔率）。无则纯模型降级。
THE_ODDS_API_KEY=

# DeepSeek LLM API key（生成中文赛事前瞻/小结）
DEEPSEEK_API_KEY=

# Gemini（生成英文赛后小结）。GEMINI_MODEL 可选，缺省见 src/lib/ai/gemini.ts。
GEMINI_API_KEY=
GEMINI_MODEL=

# Cloudflare Turnstile（人机验证）。Site key 给前端、Secret key 仅服务端。
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# 定时任务密钥（保护 /api/cron/*）。Vercel Cron 自动带 Authorization: Bearer <CRON_SECRET>；
# 外部定时服务（cron-job.org 等）用同一密钥经 Authorization 或 x-cron-secret 头调用。
CRON_SECRET=

# IndexNow 密钥（结算后向 Bing/Yandex 推送收录，绝不含 Google）。无则跳过推送。
INDEXNOW_KEY=
